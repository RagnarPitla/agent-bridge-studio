{
  "name": "agent-bridge-studio",
  "version": "0.1.0",
  "private": false,
  "description": "Design for a local-first CLI-agent control plane supporting GitHub Copilot CLI and Claude Code.",
  "type": "module",
  "main": "dist/main.cjs",
  "license": "MIT",
  "scripts": {
    "check:tools": "bash scripts/check-tools.sh",
    "check:docs": "node scripts/check-docs.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "detect": "tsx scripts/detect-agents.ts",
    "build:app": "node esbuild.config.mjs",
    "start": "npm run build:app && electron .",
    "smoke": "npm run build:app && SMOKE=1 electron .",
    "smoke:ipc": "npm run build:app && SMOKE=ipc electron .",
    "test:unit": "tsx test/activity.test.ts",
    "test": "bash scripts/test.sh"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "electron": "^33.4.11",
    "esbuild": "^0.24.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
